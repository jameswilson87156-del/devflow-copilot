# DevFlow Copilot safe environment example.
# Copy values into server-side environment variables or a private ignored file.
# Do not commit real API keys, passwords, tokens, domains, server IPs, or certificate paths.

# Spring profile.
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# Database.
# For quick local demo, dev profile uses H2 and these can stay blank.
# For MySQL/prod, set these only on the server.
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# AI Provider.
# Public portfolio demo can use local-rule without a real provider key.
DEVFLOW_AI_PROVIDER=local-rule
DEVFLOW_AI_BASE_URL=
DEVFLOW_AI_MODEL=local-rule-mvp
DEVFLOW_AI_API_KEY=
DEVFLOW_AI_FALLBACK_TO_LOCAL=true
DEVFLOW_AI_TIMEOUT_SECONDS=60
DEVFLOW_AI_MAX_TOKENS=2048

# Optional frontend screenshot helper values.
# DEVFLOW_SCREENSHOT_URL=http://127.0.0.1:5174
# DEVFLOW_API_URL=http://127.0.0.1:18081/api
